FROM python:3.12-slim

WORKDIR /app

# 安装依赖
RUN pip install --no-cache-dir \
    fastapi==0.115.0 \
    uvicorn==0.30.0 \
    sqlalchemy==2.0.31 \
    pydantic==2.7.0 \
    python-jose[cryptography]==3.3.0 \
    passlib[bcrypt]==1.7.4 \
    loguru==0.7.2 \
    Pillow==10.3.0

# 复制代码
COPY src/ ./src/
COPY main.py ./

# 暴露端口
EXPOSE 6290

# 启动命令
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "6290"]
